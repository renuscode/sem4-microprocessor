                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0000H,0001H,0003H,0002H,0004H
COUNT EQU 0005H
KEY DW 0000H
RES DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV CX,COUNT
        MOV SI,OFFSET ARRAY
        MOV RES,00H
L1:
        MOV AX,[SI]
        CMP AX,KEY
        JE L2
        INC SI
        INC SI
        LOOP L1
        HLT
L2:     MOV RES,01H
        HLT
CODE ENDS
END
