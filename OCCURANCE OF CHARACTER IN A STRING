                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
STR1 DB "APPLE"
CHAR DB 'E'
RES DB 00H
COUNT EQU 05H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA,ES:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV ES,AX
        MOV CL,COUNT
        LEA DI,STR1
        MOV AL,CHAR
        CLD
L2: SCASB
        JNZ L1
        MOV RES,01H
        JMP L3
L1:MOV RES,00H
   DEC CL
   JNZ L2
L3: HLT
CODE ENDS
END
